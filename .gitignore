.DS_Store
node_modules
.env.local
.env*.local
.next
out
tsconfig.tsbuildinfo
scripts/logs/
scripts/clerk-id-map.json

# clerk configuration (can include secrets)
/.clerk/

# .claude/ is session/routine bookkeeping (worktrees, qa-sentry bookmark, …) —
# never track it, so a stray add/commit can't sweep it in. launch.json is the
# one deliberate exception.
.claude/*
!.claude/launch.json

# python bytecode from scripts/
__pycache__/
*.pyc
